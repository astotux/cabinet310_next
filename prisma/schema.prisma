// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id          Int      @id @default(autoincrement())
  service     String
  master      String
  date        String
  time        String
  clientName  String
  clientPhone String
  createdAt   DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  rating    Int
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Price {
  id          Int      @id @default(autoincrement())
  service     String
  description String?
  category    String
  master      String
  duration    Int      // Длительность в минутах
  price       Int
  image       String?
  createdAt   DateTime @default(now())
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
