// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id          Int      @id @default(autoincrement())
  service     String
  master      String
  date        String
  time        String
  clientName  String
  clientPhone String?  // Теперь необязательное поле для VK записей
  vkProfile   String?  // Ссылка на VK профиль (vk.com/id123456 или vk.com/username)
  vkUserId    Int?     // ID пользователя ВК для уведомлений
  comment     String?
  customPrice Int?     // Свободная цена, установленная вручную
  createdAt   DateTime @default(now())
}

model BlockedSlot {
  id        Int      @id @default(autoincrement())
  master    String
  date      String
  time      String
  reason    String?
  createdAt DateTime @default(now())
}

model Review {
  id        Int           @id @default(autoincrement())
  name      String
  rating    Int
  text      String
  service   String?
  approved  Boolean       @default(false)
  createdAt DateTime      @default(now())
  photos    ReviewPhoto[]
}

model ReviewPhoto {
  id        Int      @id @default(autoincrement())
  reviewId  Int
  imageUrl  String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Price {
  id          Int      @id @default(autoincrement())
  service     String
  description String?
  category    String
  master      String
  duration    Int      // Длительность в минутах
  price       Int
  oldPrice    Int?     // Старая цена для акций (опционально)
  image       String?
  createdAt   DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?  @unique
  password  String   // Хешированный пароль
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model VKUserState {
  id            Int      @id @default(autoincrement())
  vkUserId      Int      @unique
  currentState  String   // DialogState enum (idle, selecting_service, etc.)
  bookingData   String?  // JSON с промежуточными данными бронирования
  lastActivity  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
